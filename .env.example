# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-super-secret-key-min-32-chars

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aep-migrator

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Adobe IMS (Default - users will add their own)
ADOBE_IMS_URL=https://ims-na1.adobelogin.com
ADOBE_PLATFORM_URL=https://platform.adobe.io
ADOBE_REACTOR_URL=https://reactor.adobe.io

# JWT Settings
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
